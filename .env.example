# Producción — copia como .env y rellena los valores reales
# cp .env.example .env
#
# Este archivo es para el stack de producción (docker-compose.yml en la raíz).
# Para desarrollo local usa backend/api/.env.example en su lugar.

# Base de datos — contenedor postgres en la red database_default
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bd_089
DB_USER=mas089_panel_rw
DB_PASSWORD=

# JWT — genera con: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_EXPIRE_HOURS=8

# CORS — origen exacto desde donde el navegador llama a la API
CORS_ORIGINS=https://panel-incidentes.doti-ia.com
