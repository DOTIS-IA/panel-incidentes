# Copia este archivo como .env y rellena los valores reales
# cp .env.example .env

DB_HOST=localhost
DB_PORT=5433
DB_NAME=bd_089
DB_USER=postgres
DB_PASSWORD=postgres

# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_EXPIRE_HOURS=8
DATA_DEFAULT_LIMIT=500
DATA_MAX_LIMIT=2000

# Orígenes permitidos para CORS (separados por coma si hay más de uno)
CORS_ORIGINS=http://localhost:5173

# Configuración SMTP para envío de correos (opcional en local)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_NAME=Panel Incidentes
