# Copia este archivo como .env y rellena los valores reales
# cp .env.example .env

# Usa localhost solo si PostgreSQL corre fuera de Docker.
# Si la BD vive en otro contenedor, usa el nombre del contenedor o alias de red.
DB_HOST=localhost
DB_PORT=5433
DB_NAME=bd_089
DB_USER=postgres
DB_PASSWORD=postgres

# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_EXPIRE_HOURS=8

# Orígenes permitidos para CORS (separados por coma si hay más de uno)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174
